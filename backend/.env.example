# Groq API key (free tier: https://console.groq.com/keys)
GROQ_API_KEY=

# Model names (defaults shown — override only if needed)
CHAT_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Storage paths (relative to backend/ working directory)
UPLOAD_DIR=data/uploads
CHROMA_PERSIST_DIR=data/chroma_db
# Local embedding model cache. Must live on persisted/durable storage in
# production (e.g. the same mounted disk as CHROMA_PERSIST_DIR) so the model
# doesn't re-download from huggingface.co on every restart.
HF_CACHE_DIR=data/hf_cache

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval
RETRIEVAL_TOP_K=5

# Upload limits
MAX_FILE_SIZE_MB=50

# CORS: comma-separated list of allowed frontend origins, or "*" for all
CORS_ALLOWED_ORIGINS=*

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
